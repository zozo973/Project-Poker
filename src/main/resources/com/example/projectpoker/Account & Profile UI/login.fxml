<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.*?>
<?import java.util.*?>
<?import javafx.scene.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>
<?import javafx.geometry.Insets?>

<VBox alignment="CENTER" spacing="15.0"
      xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.example.projectpoker.controller.LoginController"
      prefHeight="400.0" prefWidth="350.0">

    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0"/>
    </padding>

    <!-- Title -->
    <Label text="Log Into Account" style="-fx-font-size: 20px; -fx-font-weight: bold;"/>

    <!-- Username field -->
    <Label text="Username"/>
    <TextField fx:id="usernameField" promptText="Enter username"/>

    <!-- Password field -->
    <Label text="Password"/>
    <PasswordField fx:id="passwordField" promptText="Enter password"/>

    <!-- Login button -->
    <Button text="Login" onAction="#handleLogin"/>

    <!-- Message label for errors/success -->
    <Label fx:id="messageLabel" text=""/>

    <!-- Link to Register -->
    <Label text="Already have an account?"/>
    <Button text="Go to Register" onAction="#goToRegister"/>
</VBox>

