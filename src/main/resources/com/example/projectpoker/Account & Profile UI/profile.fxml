<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.VBox?>
<?import javafx.geometry.Insets?>

<VBox alignment="CENTER" spacing="15.0"
      xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.example.projectpoker.controller.ProfileController"
      prefHeight="400.0" prefWidth="350.0">

    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0"/>
    </padding>

    <!-- Title -->
    <Label text="Profile" style="-fx-font-size: 20px; -fx-font-weight: bold;"/>

    <!--    Username -->
    <Label text="Username"/>
    <Label fx:id="usernameLabel" text=""/>

    <!--    Total Hands -->
    <Label text="Total Hands Played"/>
    <Label fx:id="totalHandsLabel" text=""/>

    <!--    Total Wins -->
    <Label text="Total Wins"/>
    <Label fx:id="totalWinsLabel" text=""/>

    <!--    Current Balance -->
    <Label text="Current Balance"/>
    <Label fx:id="balanceLabel" text=""/>

    <!-- Message label for errors/success -->
    <Label fx:id="messageLabel" text=""/>

    <!-- Button for logging out -->
    <Button text="Log Out" onAction="#logOut"/>

</VBox>