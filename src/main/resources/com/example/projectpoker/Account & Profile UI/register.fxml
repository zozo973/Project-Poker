<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>
<?import javafx.geometry.Insets?>

<VBox alignment="CENTER" spacing="15.0"
      xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.example.projectpoker.controller.RegisterController"
      prefHeight="400.0" prefWidth="350.0">

    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0"/>
    </padding>

    <!-- Title -->
    <Label text="Create Account" style="-fx-font-size: 20px; -fx-font-weight: bold;"/>

    <!-- Username field -->
    <Label text="Username"/>
    <TextField fx:id="usernameField" promptText="Enter username"/>

    <!-- Email field -->
    <Label text="Email"/>
    <TextField fx:id="emailField" promptText="Enter email"/>

    <!-- Password field -->
    <Label text="Password"/>
    <PasswordField fx:id="passwordField" promptText="Enter password"/>

    <!-- Confirm password field -->
    <Label text="Confirm Password"/>
    <PasswordField fx:id="confirmPasswordField" promptText="Confirm password"/>

    <!-- Register button -->
    <Button text="Register" onAction="#handleRegister"/>

    <!-- Message label for errors/success -->
    <Label fx:id="messageLabel" text=""/>

    <!-- Log out button -->
    <Label text="Already have an account?"/>
    <Button text="Go to Login" onAction="#goToLogin"/>

</VBox>