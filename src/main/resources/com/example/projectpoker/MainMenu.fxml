<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox alignment="CENTER" spacing="15.0"
      xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.example.projectpoker.controller.MainMenuController"
      prefHeight="400.0" prefWidth="350.0">

    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0"/>
    </padding>

    <!-- Title -->
    <Label text="Main Menu" style="-fx-font-size: 20px; -fx-font-weight: bold;"/>

    <!-- Message label for errors/success -->
    <Label fx:id="messageLabel"/>

    <!-- Link to Game -->
    <Button text="Start Game" onAction="#goToGame"/>

    <!-- Link to Profile menu -->
    <Button text="Profile" onAction="#goToProfile"/>

    <!-- Link to Options menu -->
    <Button text="Options" onAction="#goToOptions"/>

    <!-- Link to Exit -->
    <Button text="Exit" onAction="#exitGame"/>

</VBox>