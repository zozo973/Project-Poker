<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Spinner?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.StackPane?>

<VBox alignment="TOP_CENTER" spacing="12.0"
      xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.example.projectpoker.controller.OptionsMenuController"
      stylesheets="@/CSS/Menu's/OptionsStyle.css"
      styleClass="root">

    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0"/>
    </padding>

    <Label text="Options Menu" style="-fx-font-size: 35px; -fx-font-weight: bold; -fx-text-fill: #d4af37;">
        <VBox.margin>
            <Insets top="30.0"/>
        </VBox.margin>
    </Label>

    <!--Number of Opponents-->
    <HBox alignment="CENTER" spacing="10.0">
        <Label text="Opponents" prefWidth="100.0"/>
        <Spinner fx:id="opponentsSpinner" prefWidth="150.0"/>
    </HBox>

    <!---Difficulty-->
    <VBox spacing="2.0" alignment="CENTER">
        <HBox alignment="CENTER" spacing="10.0">
            <Label text="Difficulty" prefWidth="100.0"/>
            <ComboBox fx:id="difficultyComboBox" onAction="#onDifficultyChanged" prefWidth="150.0"/>
        </HBox>
        <Label fx:id="difficultyDescriptionLabel" wrapText="true" style="-fx-font-size: 11px; " styleClass="description" alignment="CENTER">
            <VBox.margin>
                <Insets top="10.0"/>
            </VBox.margin>
        </Label>
    </VBox>

<!--    <HBox alignment="CENTER_LEFT" spacing="10.0">-->
<!--        <Label text="Theme" prefWidth="130.0"/>-->
<!--        <CheckBox fx:id="darkModeCheckBox" text="Dark Mode"/>-->
<!--    </HBox>-->

    <!-- Card Back Selection -->
    <VBox alignment="CENTER" spacing="5.0">
        <Label text="Card Style" style="-fx-font-size: 12px;"/>
        <HBox alignment="CENTER" spacing="15.0">
            <Button text="&lt;" onAction="#previousCardBack" styleClass="nav-button"/>
            <StackPane styleClass="image-frame">
                <ImageView fx:id="cardBackPreview" fitHeight="75.0" preserveRatio="true"/>
            </StackPane>
            <Button text="&gt;" onAction="#nextCardBack" styleClass="nav-button"/>
        </HBox>
    </VBox>

    <!-- Board Selection -->
    <VBox alignment="CENTER" spacing="5.0">
        <Label text="Board Style" style="-fx-font-size: 12px;"/>
        <HBox alignment="CENTER" spacing="15.0">
            <Button text="&lt;" onAction="#previousBoard" styleClass="nav-button"/>
            <StackPane styleClass="image-frame">
                <ImageView fx:id="boardPreview" fitWidth="225.0" preserveRatio="true"/>
            </StackPane>
            <Button text="&gt;" onAction="#nextBoard" styleClass="nav-button"/>
        </HBox>
    </VBox>

<!--    <Label fx:id="boardNameLabel"/>-->

    <Label fx:id="messageLabel" styleClass="message-label"/>

    <!-- Action Buttons -->
    <HBox alignment="CENTER" spacing="10.0">
        <Button text="Save" onAction="#savePreferences" styleClass="action-button"/>
        <Button text="Back" onAction="#goToMain" styleClass="action-button"/>
    </HBox>

    <Region prefHeight="8.0"/>
</VBox>