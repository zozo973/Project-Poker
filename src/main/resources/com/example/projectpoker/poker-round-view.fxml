<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>

<AnchorPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.example.projectpoker.controller.RoundController"
            prefHeight="400.0" prefWidth="600.0">

                <Label fx:id="potLabel"
                       text="Pot"/>

                <Label fx:id="toCallLabel"
                       text="To Call"/>

                <Label fx:id="balanceLabel"
                       text="Balance"/>

            </VBox>

        </StackPane>

    </center>


    <right>

        <VBox spacing="10"
              prefWidth="220"
              style="-fx-padding: 10;">

            <Label text="Coach / Chat Window"/>

            <TextArea prefHeight="300"
                      editable="false"
                      wrapText="true"/>

            <TextField promptText="User input"/>

        </VBox>

    </right>


    <bottom>

        <VBox spacing="10"
              alignment="CENTER"
              style="-fx-padding: 15;">


            <Slider fx:id="betSlider"
                    prefWidth="400"
                    showTickMarks="true"
                    showTickLabels="true"/>


            <HBox spacing="20"
                  alignment="CENTER">

                <Button fx:id="toCallButton"
                        text="Check / Call"
                        prefWidth="120"
                        onAction="#handleCall"/>

                <Button fx:id="betButton"
                        text="Raise"
                        prefWidth="120"
                        onAction="#handleRaise"/>

                <Button fx:id="foldButton"
                        text="Fold"
                        prefWidth="120"
                        onAction="#handleFold"/>

                <Button fx:id="allInButton"
                        text="All In"
                        prefWidth="120"
                        onAction="#handleAllIn"/>

            </HBox>

        </VBox>

    </bottom>

</BorderPane>