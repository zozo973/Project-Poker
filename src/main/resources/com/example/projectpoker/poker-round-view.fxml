<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.example.projectpoker.controller.RoundController"
            fx:id="mainBorderPane"
            prefWidth="1110"
            prefHeight="620"
            stylesheets="@/CSS/Menu's/PokerRoundStyle.css">

    <fx:define>
        <ToggleGroup fx:id="aiModeGroup"/>
    </fx:define>

    <top>
        <HBox spacing="20" alignment="CENTER_LEFT" styleClass="round-top-bar">
            <MenuButton text="Settings / Options" styleClass="round-settings-button">
                <items>
                    <MenuItem text="Quit to Main Menu" onAction="#quitToMainMenu"/>
                    <CheckMenuItem fx:id="fullscreenToggle" text="Fullscreen" onAction="#toggleFullscreen"/>
                    <CheckMenuItem fx:id="darkModeToggle" text="Dark Mode" onAction="#toggleDarkMode"/>
                </items>
            </MenuButton>
        </HBox>
    </top>

    <center>
        <VBox alignment="TOP_CENTER">

            <StackPane VBox.vgrow="NEVER">
                <AnchorPane fx:id="tablePane"
                            minWidth="820"
                            prefWidth="820"
                            minHeight="390"
                            prefHeight="390"/>

                <Button fx:id="startGameButton"
                        text="Start Game"
                        styleClass="start-button"
                        StackPane.alignment="CENTER"
                        prefWidth="120"
                        onAction="#onStartGameButton"/>
            </StackPane>

            <HBox spacing="30" alignment="CENTER" styleClass="round-status-bar" VBox.vgrow="NEVER">
                <VBox spacing="2" alignment="CENTER_LEFT">
                    <Label fx:id="balanceLabel" text="Balance"/>
                    <Label fx:id="toCallLabel" text="To Call"/>
                </VBox>
                <VBox spacing="2" alignment="CENTER_LEFT">
                    <Label fx:id="phaseLabel" text="Phase"/>
                    <Label fx:id="roundCounterLabel" text="Rounds Left"/>
                    <Label fx:id="potLabel" text="Pot"/>
                </VBox>
                <Spinner fx:id="betSpinner" prefWidth="160" styleClass="round-spinner"/>
            </HBox>

            <HBox spacing="12" alignment="CENTER" styleClass="action-row" VBox.vgrow="NEVER">
                <Button fx:id="startRoundButton"
                        text="Start Round"
                        styleClass="start-button"
                        prefWidth="110"
                        disable="true"
                        onAction="#onStartRoundButton"/>
                <Button fx:id="toCallButton"
                        text="Check / Call"
                        styleClass="menu-button"
                        prefWidth="110"
                        onAction="#handleCall"/>
                <Button fx:id="betButton"
                        text="Raise"
                        styleClass="menu-button"
                        prefWidth="110"
                        onAction="#handleRaise"/>
                <Button fx:id="foldButton"
                        text="Fold"
                        styleClass="menu-button danger-button"
                        prefWidth="110"
                        onAction="#handleFold"/>
                <Button fx:id="allInButton"
                        text="All In"
                        styleClass="menu-button warning-button"
                        prefWidth="110"
                        onAction="#handleAllIn"/>
            </HBox>

        </VBox>
    </center>

    <right>
        <VBox spacing="8" prefWidth="280" styleClass="coach-panel">
            <Label text="AI Coach" styleClass="panel-title"/>

            <HBox spacing="4">
                <ToggleButton fx:id="btnSafe" text="SAFE" onAction="#handleAiMode" styleClass="mode-toggle" toggleGroup="$aiModeGroup"/>
                <ToggleButton fx:id="btnNormal" text="NORMAL" onAction="#handleAiMode" selected="true" styleClass="mode-toggle" toggleGroup="$aiModeGroup"/>
                <ToggleButton fx:id="btnRisky" text="RISKY" onAction="#handleAiMode" styleClass="mode-toggle" toggleGroup="$aiModeGroup"/>
            </HBox>

            <Button fx:id="btnGenerate" text="Get AI Advice" maxWidth="Infinity" onAction="#handleAiGenerate" styleClass="menu-button"/>
            <Label text="Result:" styleClass="section-title"/>

            <VBox spacing="6" styleClass="coach-result-box" VBox.vgrow="NEVER">
                <Label fx:id="aiActionLabel" text="Action: -" styleClass="coach-action"/>
                <Label fx:id="aiReasonLabel" text="Reason: -" wrapText="true"/>
                <Label fx:id="aiStatusLabel" text="Press the button to get advice." styleClass="coach-status" wrapText="true"/>
                <Separator/>
                <Label text="AI advice is for reference only. Use your own judgement." wrapText="true" styleClass="coach-warning"/>
            </VBox>

            <Label text="Game Actions" styleClass="section-title"/>
            <TextArea fx:id="gameLogTextArea"
                      editable="false"
                      wrapText="true"
                      focusTraversable="false"
                      styleClass="round-log-area"
                      VBox.vgrow="ALWAYS"/>
        </VBox>
    </right>

</BorderPane>
